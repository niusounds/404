# EditorConfig helps maintain consistent coding styles for multiple developers working on the same project across various editors and IDEs.
# 詳細: https://editorconfig.org/

root = true

# HTML, CSS, JS 共通設定
[*.{html,css,js}]
charset = utf-8
indent_style = space
indent_size = 2
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown
[*.md]
charset = utf-8
indent_style = space
indent_size = 2
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = false

# YAML
[*.yml]
indent_style = space
indent_size = 2
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
